{
  "name": "infinityfg",
  "private": true,
  "version": "1.0.0",
  "description": "InfinityFG farming automation and progression simulator",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:pipeline": "npx tsx scripts/orchestrator.ts",
    "simulate:qa": "npx tsx simulation/qa_runner.ts",
    "simulate:qa:strict": "npx tsx simulation/qa_runner.ts --failOnRegression=true",
    "simulate:progression": "npx tsx simulation/progression_sim.ts",
    "simulate:balance": "npx tsx simulation/balance_sim.ts",
    "simulate:roi": "npx tsx simulation/machine_roi_sim.ts",
    "validate:system": "npm run lint && npm run build && npm run simulate:qa:strict"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "appwrite": "^23.0.0",
    "autoprefixer": "^10.4.27",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
